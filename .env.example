# ==============================================================================
# WEELAKE · V-LAKE — environment variables template
# Copy to `.env.local` for local dev, or set in Vercel / Railway / GitHub Actions
# ==============================================================================

# --- Supabase ---
# Get from https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL="https://gjfchiipsqhlsbjkkmdi.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGci..."
SUPABASE_SERVICE_ROLE_KEY="eyJhbGci..."           # server-only, DO NOT ship to client
SUPABASE_DB_URL="postgresql://postgres:PASSWORD@db.gjfchiipsqhlsbjkkmdi.supabase.co:5432/postgres"

# --- Copernicus CDS (Climate Data Store) ---
# Register at https://cds.climate.copernicus.eu/user/register
# Then copy UID:KEY pair from https://cds.climate.copernicus.eu/api-how-to
CDSAPI_URL="https://cds.climate.copernicus.eu/api/v2"
CDSAPI_KEY="UID:API_KEY_HERE"

# --- Copernicus Marine (CMEMS) ---
# Register at https://data.marine.copernicus.eu/register
COPERNICUS_MARINE_USER="your_username"
COPERNICUS_MARINE_PASSWORD="your_password"

# --- Open-Meteo (no key required, but rate-limit friendly if set) ---
OPENMETEO_BASE_URL="https://api.open-meteo.com/v1"
OPENMETEO_MARINE_URL="https://marine-api.open-meteo.com/v1"

# --- Map provider ---
# Protomaps API key optional (or self-host PMTiles); default uses public demo tiles
NEXT_PUBLIC_PROTOMAPS_KEY=""
NEXT_PUBLIC_MAP_STYLE_URL="https://basemaps.cartocdn.com/gl/positron-gl-style/style.json"

# --- Public site config ---
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="V-Lake"

# --- Analytics (optional) ---
NEXT_PUBLIC_PLAUSIBLE_DOMAIN="weelake.com"

# --- Sentry (optional) ---
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
